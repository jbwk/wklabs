    <script>
        // Smooth scrolling fix for Google Sites Iframe
        document.querySelectorAll('a.nav-link').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault(); // Prevents the iframe from trying to navigate to a new page
                const targetId = this.getAttribute('href');
                const targetElement = document.querySelector(targetId);
                
                if (targetElement) {
                    targetElement.scrollIntoView({
                        behavior: 'smooth'
                    });
                }
            });
        });

        // Simple Intersection Observer for scroll-linked animations
        const observerOptions = {
            threshold: 0.1
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = "1";
                    entry.target.style.transform = "translateY(0)";
                }
            });
        }, observerOptions);

        document.querySelectorAll('.tool-card, #learning > div > a, .cta-box').forEach(el => {
            el.style.opacity = "0";
            el.style.transform = "translateY(20px)";
            el.style.transition = "all 0.6s ease-out";
            observer.observe(el);
        });

        // --- ART GENERATOR LOGIC ---
        const quotes = [
            "Walk in stupid every day",
            "Ship of Fools",
            "A white wall is a missed opportunity",
            "No sharp stuff",
            "Shut up when someone is talking",
            "The Work Comes First",
            "It’s not mathematics, it’s jazz",
            "Independence is everything",
            "Creativity is a place",
            "Difficult is worth doing"
        ];

        const apiKey = "";
        const canvas = document.getElementById('artCanvas');
        const ctx = canvas.getContext('2d');
        const generateBtn = document.getElementById('generateBtn');
        const saveInstruction = document.getElementById('saveInstruction');
        const placeholder = document.getElementById('artPlaceholder');
        const loading = document.getElementById('artLoading');
        const errorMsg = document.getElementById('artError');

        // Text wrapping utility for Canvas
        function wrapText(context, text, x, y, maxWidth, lineHeight) {
            const words = text.split(' ');
            let line = '';
            let lines = [];

            for(let n = 0; n < words.length; n++) {
                let testLine = line + words[n] + ' ';
                let metrics = context.measureText(testLine);
                if (metrics.width > maxWidth && n > 0) {
                    lines.push(line.trim());
                    line = words[n] + ' ';
                } else {
                    line = testLine;
                }
            }
            lines.push(line.trim());

            // Center vertically
            let totalHeight = lines.length * lineHeight;
            let startY = y - (totalHeight / 2) + (lineHeight / 2);

            for(let i = 0; i < lines.length; i++) {
                context.fillText(lines[i], x, startY + (i * lineHeight));
            }
        }

        // Fetch with exponential backoff for reliability
        async function fetchWithRetry(url, options, retries = 5) {
            const delays = [1000, 2000, 4000, 8000, 16000];
            for (let i = 0; i < retries; i++) {
                try {
                    const response = await fetch(url, options);
                    if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
                    return await response.json();
                } catch (error) {
                    if (i === retries - 1) throw error;
                    await new Promise(res => setTimeout(res, delays[i]));
                }
            }
        }

        async function generateArt() {
            // Update UI State
            placeholder.classList.add('hidden');
            errorMsg.classList.add('hidden');
            canvas.classList.add('hidden');
            loading.classList.remove('hidden');
            saveInstruction.classList.add('hidden');
            generateBtn.disabled = true;
            generateBtn.classList.add('opacity-50', 'cursor-not-allowed');

            const randomQuote = quotes[Math.floor(Math.random() * quotes.length)];
            
            // Randomize visual style prompts for maximum variety
            const styles = [
                "punk rock collage", "vibrant abstract expressionism", 
                "messy creative graphic design", "neon cyberpunk distortion", 
                "bold bauhaus geometric shapes", "psychedelic colorful fluid simulation", 
                "irreverent surrealist dreamscape", "street art graffiti explosion",
                "high contrast monochromatic with one vibrant accent color",
                "glitch art aesthetic"
            ];
            const randomStyle = styles[Math.floor(Math.random() * styles.length)];
            const prompt = `Abstract background art, ${randomStyle}, vivid vibrant colors, highly creative, no text, texture, modern, irreverent, 4k resolution`;

            try {
                const url = `https://generativelanguage.googleapis.com/v1beta/models/imagen-4.0-generate-001:predict?key=${apiKey}`;
                const result = await fetchWithRetry(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        instances: { prompt: prompt },
                        parameters: { sampleCount: 1 }
                    })
                });

                const base64Image = result.predictions[0].bytesBase64Encoded;
                const imageUrl = `data:image/png;base64,${base64Image}`;

                // Process and draw onto canvas
                const img = new Image();
                img.onload = () => {
                    ctx.clearRect(0, 0, canvas.width, canvas.height);
                    ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
                    
                    // Add subtle dark overlay to ensure text is always readable
                    ctx.fillStyle = 'rgba(0,0,0,0.4)';
                    ctx.fillRect(0, 0, canvas.width, canvas.height);

                    // Setup Typography for Quote
                    ctx.fillStyle = 'white';
                    
                    ctx.font = 'bold 90px "Inter", sans-serif';
                    ctx.textAlign = 'center';
                    ctx.textBaseline = 'middle';

                    wrapText(ctx, randomQuote.toUpperCase(), canvas.width / 2, canvas.height / 2, canvas.width - 160, 110);

                    // Add W+K LABS Signature
                    ctx.font = 'bold 28px "Inter", sans-serif';
                    ctx.letterSpacing = "4px";
                    
                    ctx.fillText("W+K LABS", canvas.width / 2, canvas.height - 80);

                    // Reveal completed art
                    loading.classList.add('hidden');
                    canvas.classList.remove('hidden');
                    saveInstruction.classList.remove('hidden');
                    saveInstruction.classList.add('flex');
                    
                    generateBtn.disabled = false;
                    generateBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                };
                img.src = imageUrl;

            } catch (error) {
                console.error("Art Generation Error:", error);
                loading.classList.add('hidden');
                errorMsg.classList.remove('hidden');
                
                generateBtn.disabled = false;
                generateBtn.classList.remove('opacity-50', 'cursor-not-allowed');
            }
        }

        generateBtn.addEventListener('click', generateArt);

        // --- CHATBOT LOGIC ---
        const chatWidget = document.getElementById('chatWidget');
        const openChatBtn = document.getElementById('openChatBtn');
        const closeChatBtn = document.getElementById('closeChatBtn');
        const chatLog = document.getElementById('chatLog');
        const chatForm = document.getElementById('chatForm');
        const chatInput = document.getElementById('chatInput');
        const sendChatBtn = document.getElementById('sendChatBtn');

        let chatHistory = [];

        // The system prompt teaches the bot about the specific contents of your site
        const systemPrompt = `You are a helpful IT assistant for the W+K (Wieden+Kennedy) AI Tools Hub.
        Answer questions based ONLY on the following information about our tools and policies. Keep answers concise, friendly, and professional. 

        Available Tools:
        - Google Gemini: Main enterprise AI platform. Includes Nano Banana (images), Veo (video), Canvas (custom scripts), and Custom Gems (contextual chats).
        - Gemini Enterprise: Access to custom agents like W+K Creative Agent, Deep Research Agent, Idea Generation Agent, and the ability to Build a Custom Agent.
        - Google NotebookLM: Gather sources to output podcasts, videos, reports.
        - Adobe Firefly: Generative AI in Creative Cloud (requires Adobe CC license).
        - Google Workspace Studio: Automation hub for Google apps.

        Privacy & Security:
        - Data is secure and NOT used for public training.
        - Strictly private, not subject to human review.
        - Enterprise-grade security (Google Cloud, VPC-SC, CMEK, HIPAA).

        Other Info:
        - Need a different tool? Fill out the Platform Request Form.
        - Learning resources available: Google AI Learning Hub, W+K x OK Tomorrow, AI on IT Essentials.
        - To schedule a meeting or build a custom agent, use the scheduler link.`;

        function toggleChat() {
            const isHidden = chatWidget.classList.contains('opacity-0');
            if (isHidden) {
                chatWidget.classList.remove('translate-y-8', 'opacity-0', 'pointer-events-none');
                chatInput.focus();
            } else {
                chatWidget.classList.add('translate-y-8', 'opacity-0', 'pointer-events-none');
            }
        }

        openChatBtn.addEventListener('click', toggleChat);
        closeChatBtn.addEventListener('click', toggleChat);

        function addMessageToUI(text, isUser) {
            const msgDiv = document.createElement('div');
            msgDiv.className = isUser
                ? 'bg-fuchsia-500 text-black self-end p-3 rounded-2xl rounded-tr-sm max-w-[85%] font-medium'
                : 'bg-zinc-800 text-zinc-200 self-start p-3 rounded-2xl rounded-tl-sm max-w-[85%]';
            msgDiv.innerText = text;
            chatLog.appendChild(msgDiv);
            chatLog.scrollTop = chatLog.scrollHeight;
        }

        function addLoadingToUI() {
            const loadingDiv = document.createElement('div');
            loadingDiv.id = 'chatLoadingBubble';
            loadingDiv.className = 'bg-zinc-800 text-zinc-400 self-start p-4 rounded-2xl rounded-tl-sm flex items-center gap-2';
            loadingDiv.innerHTML = '<div class="w-1.5 h-1.5 bg-zinc-500 rounded-full animate-bounce"></div><div class="w-1.5 h-1.5 bg-zinc-500 rounded-full animate-bounce" style="animation-delay: 0.15s"></div><div class="w-1.5 h-1.5 bg-zinc-500 rounded-full animate-bounce" style="animation-delay: 0.3s"></div>';
            chatLog.appendChild(loadingDiv);
            chatLog.scrollTop = chatLog.scrollHeight;
        }

        function removeLoadingFromUI() {
            const loadingDiv = document.getElementById('chatLoadingBubble');
            if (loadingDiv) loadingDiv.remove();
        }

        chatForm.addEventListener('submit', async (e) => {
            const message = chatInput.value.trim();
            if (!message) return;

            // UI Updates
            chatInput.value = '';
            chatInput.disabled = true;
            sendChatBtn.disabled = true;
            addMessageToUI(message, true);
            addLoadingToUI();

            // Add to history payload
            chatHistory.push({ role: 'user', parts: [{ text: message }] });

            try {
                const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
                const payload = {
                    contents: chatHistory,
                    systemInstruction: { parts: [{ text: systemPrompt }] }
                };

                const result = await fetchWithRetry(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (!result.candidates || !result.candidates[0]) {
                    throw new Error("Invalid response from API");
                }

                const botResponse = result.candidates[0].content.parts[0].text;

                // Add bot response to history payload
                chatHistory.push({ role: 'model', parts: [{ text: botResponse }] });

                removeLoadingFromUI();
                addMessageToUI(botResponse, false);

            } catch (error) {
                console.error("Chat Error:", error);
                removeLoadingFromUI();
                addMessageToUI("Sorry, I encountered an error. " + (error.message || "Please try again later."), false);
                // Remove the failed user message from history so context isn't corrupted
                chatHistory.pop();
            } finally {
                chatInput.disabled = false;
                sendChatBtn.disabled = false;
                chatInput.focus();
            }
        });
    </script>
</body>
</html>
